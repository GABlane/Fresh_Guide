<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@android:color/white"
    tools:context=".MainActivity">

    <!-- Fixed Header -->
    <LinearLayout
        android:id="@+id/header_bar"
        android:layout_width="match_parent"
        android:layout_height="38dp"
        android:orientation="horizontal"
        android:paddingStart="8dp"
        android:paddingEnd="16dp"
        android:gravity="center_vertical"
        android:background="@color/surface_white">

        <ImageButton
            android:id="@+id/header_back"
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:layout_marginEnd="8dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:contentDescription="@string/action_back"
            android:padding="4dp"
            android:src="@drawable/ic_arrow_back_24"
            android:tint="@color/text_primary"
            android:visibility="gone" />

        <TextView
            android:id="@+id/title_home"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="@string/dashboard_header"
            android:gravity="center_vertical"
            android:textSize="11sp"
            android:textStyle="bold"
            android:letterSpacing="0.08"
            android:textAllCaps="true"
            android:textColor="@color/text_primary" />
    </LinearLayout>

    <!-- Fragment container — NavHostFragment fills this area -->
    <androidx.fragment.app.FragmentContainerView
        android:id="@+id/nav_host_fragment"
        android:name="androidx.navigation.fragment.NavHostFragment"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        app:defaultNavHost="true"
        app:navGraph="@navigation/nav_graph" />

    <!-- Bottom Navigation (custom) -->
    <FrameLayout
        android:id="@+id/nav_bar_container"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="6dp"
        android:layout_marginBottom="10dp"
        android:paddingStart="16dp"
        android:paddingEnd="16dp"
        android:paddingBottom="12dp"
        android:paddingTop="8dp">

        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardElevation="8dp"
            app:cardCornerRadius="28dp"
            app:cardBackgroundColor="@color/surface_white">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:paddingStart="10dp"
                android:paddingEnd="10dp"
                android:paddingTop="6dp"
                android:paddingBottom="6dp">

                <FrameLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1">

                    <LinearLayout
                        android:id="@+id/nav_item_home"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_gravity="center"
                        android:orientation="vertical"
                        android:gravity="center"
                        android:paddingStart="14dp"
                        android:paddingEnd="14dp"
                        android:paddingTop="6dp"
                        android:paddingBottom="6dp"
                        android:clickable="true"
                        android:focusable="true">

                        <ImageView
                            android:id="@+id/nav_icon_home"
                            android:layout_width="20dp"
                            android:layout_height="20dp"
                            android:src="@drawable/ic_nav_home"
                            android:tint="@color/text_hint"
                            android:contentDescription="@string/nav_home" />

                        <TextView
                            android:id="@+id/nav_text_home"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="2dp"
                            android:text="@string/nav_home"
                            android:textSize="10sp"
                            android:textColor="@color/text_hint" />
                    </LinearLayout>
                </FrameLayout>

                <FrameLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1">

                    <LinearLayout
                        android:id="@+id/nav_item_schedule"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_gravity="center"
                        android:orientation="vertical"
                        android:gravity="center"
                        android:paddingStart="14dp"
                        android:paddingEnd="14dp"
                        android:paddingTop="6dp"
                        android:paddingBottom="6dp"
                        android:clickable="true"
                        android:focusable="true">

                        <ImageView
                            android:id="@+id/nav_icon_schedule"
                            android:layout_width="20dp"
                            android:layout_height="20dp"
                            android:src="@drawable/ic_nav_schedule"
                            android:tint="@color/text_hint"
                            android:contentDescription="@string/nav_schedule" />

                        <TextView
                            android:id="@+id/nav_text_schedule"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="2dp"
                            android:text="@string/nav_schedule"
                            android:textSize="10sp"
                            android:textColor="@color/text_hint" />
                    </LinearLayout>
                </FrameLayout>

                <FrameLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1">

                    <LinearLayout
                        android:id="@+id/nav_item_settings"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_gravity="center"
                        android:orientation="vertical"
                        android:gravity="center"
                        android:paddingStart="14dp"
                        android:paddingEnd="14dp"
                        android:paddingTop="6dp"
                        android:paddingBottom="6dp"
                        android:clickable="true"
                        android:focusable="true">

                        <ImageView
                            android:id="@+id/nav_icon_settings"
                            android:layout_width="20dp"
                            android:layout_height="20dp"
                            android:src="@drawable/ic_nav_settings"
                            android:tint="@color/text_hint"
                            android:contentDescription="@string/nav_settings" />

                        <TextView
                            android:id="@+id/nav_text_settings"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="2dp"
                            android:text="@string/nav_settings"
                            android:textSize="10sp"
                            android:textColor="@color/text_hint" />
                    </LinearLayout>
                </FrameLayout>

                <FrameLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1">

                    <LinearLayout
                        android:id="@+id/nav_item_profile"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_gravity="center"
                        android:orientation="vertical"
                        android:gravity="center"
                        android:paddingStart="14dp"
                        android:paddingEnd="14dp"
                        android:paddingTop="6dp"
                        android:paddingBottom="6dp"
                        android:clickable="true"
                        android:focusable="true">

                        <ImageView
                            android:id="@+id/nav_icon_profile"
                            android:layout_width="20dp"
                            android:layout_height="20dp"
                            android:src="@drawable/ic_nav_profile"
                            android:tint="@color/text_hint"
                            android:contentDescription="@string/nav_profile" />

                        <TextView
                            android:id="@+id/nav_text_profile"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="2dp"
                            android:text="@string/nav_profile"
                            android:textSize="10sp"
                            android:textColor="@color/text_hint" />
                    </LinearLayout>
                </FrameLayout>
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>
    </FrameLayout>

</LinearLayout>
