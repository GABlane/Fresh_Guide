<?xml version="1.0" encoding="utf-8"?>
<!--
    Root FrameLayout layers (back to front):
      1. bg_login_pattern   — tiled transparent PNG over background_default color
      2. ScrollView + card  — glassmorphism login card centered on screen
-->
<FrameLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background_default">

    <!--
        Pattern layer:
        A full-screen ImageView that tiles pattern_bg.png (your transparent PNG)
        over the background_default color. Alpha is set in code via LoginActivity
        depending on night mode: 0.12f (light) or 0.07f (dark).
        See: LoginActivity.applyPatternAlpha()
    -->
    <View
        android:id="@+id/iv_pattern"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@drawable/bg_login_pattern" />

    <!-- Scrollable content so keyboard doesn't crush the card -->
    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fillViewport="true"
        android:overScrollMode="never">

        <androidx.constraintlayout.widget.ConstraintLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:minHeight="@dimen/screen_min_height">

            <!--
                Glass card: max 360dp, sits slightly above vertical center.
                Background = bg_login_card.xml (semi-transparent + border)
                Blur effect applied in code (API 31+) on the card view itself.
            -->
            <LinearLayout
                android:id="@+id/loginCard"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:paddingStart="28dp"
                android:paddingEnd="28dp"
                android:paddingTop="44dp"
                android:paddingBottom="44dp"
                android:background="@drawable/bg_login_card"
                app:layout_constraintWidth_max="360dp"
                app:layout_constraintWidth_default="spread"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintVertical_bias="0.44"
                android:layout_marginStart="24dp"
                android:layout_marginEnd="24dp">

                <!-- Logo photo -->
                <ImageView
                    android:id="@+id/loginLogo"
                    android:layout_width="@dimen/login_logo_width"
                    android:layout_height="wrap_content"
                    android:layout_gravity="center_horizontal"
                    android:src="@drawable/logo"
                    android:contentDescription="@string/logo_description"
                    android:scaleType="fitCenter"
                    android:adjustViewBounds="true"
                    android:layout_marginBottom="32dp" />

                <!-- Login mode hint -->
                <TextView
                    android:id="@+id/tv_login_hint"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="20dp"
                    android:text="@string/login_hint_qr_mode"
                    android:textSize="13sp"
                    android:textAlignment="center"
                    android:textColor="@color/text_secondary"
                    android:lineSpacingMultiplier="1.4" />

                <!-- ── ADMIN MODE FIELDS (hidden by default) ── -->

                <!-- Email label -->
                <TextView
                    android:id="@+id/labelUsername"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/label_username"
                    android:textColor="@color/text_secondary"
                    android:textSize="12sp"
                    android:letterSpacing="0.04"
                    android:layout_marginBottom="6dp"
                    android:visibility="gone" />

                <!-- Email input -->
                <EditText
                    android:id="@+id/inputUsername"
                    android:layout_width="match_parent"
                    android:layout_height="48dp"
                    android:hint="@string/hint_admin_email"
                    android:textColorHint="@color/text_hint"
                    android:textSize="14sp"
                    android:textColor="@color/text_primary"
                    android:background="@drawable/bg_input_field"
                    android:paddingStart="14dp"
                    android:paddingEnd="14dp"
                    android:inputType="textEmailAddress"
                    android:singleLine="true"
                    android:layout_marginBottom="14dp"
                    android:visibility="gone" />

                <!-- Password label -->
                <TextView
                    android:id="@+id/labelPassword"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/label_password"
                    android:textColor="@color/text_secondary"
                    android:textSize="12sp"
                    android:letterSpacing="0.04"
                    android:layout_marginBottom="6dp"
                    android:visibility="gone" />

                <!-- Password row -->
                <FrameLayout
                    android:id="@+id/passwordRow"
                    android:layout_width="match_parent"
                    android:layout_height="48dp"
                    android:layout_marginBottom="24dp"
                    android:visibility="gone">

                    <EditText
                        android:id="@+id/inputPassword"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:hint="@string/hint_password"
                        android:textColorHint="@color/text_hint"
                        android:textSize="14sp"
                        android:textColor="@color/text_primary"
                        android:background="@drawable/bg_input_field"
                        android:paddingStart="14dp"
                        android:paddingEnd="50dp"
                        android:inputType="textPassword"
                        android:singleLine="true" />

                    <ImageButton
                        android:id="@+id/btnTogglePassword"
                        android:layout_width="40dp"
                        android:layout_height="40dp"
                        android:layout_gravity="end|center_vertical"
                        android:layout_marginEnd="6dp"
                        android:src="@drawable/ic_eye"
                        android:background="?attr/selectableItemBackgroundBorderless"
                        android:tint="@color/text_hint"
                        android:contentDescription="@string/toggle_password_visibility" />

                </FrameLayout>

                <!-- ── LOADING ── -->
                <ProgressBar
                    android:id="@+id/progress_bar"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="center_horizontal"
                    android:layout_marginBottom="12dp"
                    android:indeterminateTint="@color/green_primary"
                    android:visibility="gone" />

                <!-- ── PRIMARY BUTTON: Scan QR / Sign In ── -->
                <Button
                    android:id="@+id/btnSignIn"
                    android:layout_width="match_parent"
                    android:layout_height="52dp"
                    android:text="@string/btn_scan_qr_login"
                    android:textColor="@color/white"
                    android:textSize="13sp"
                    android:letterSpacing="0.08"

                    android:background="@drawable/bg_btn_primary"
                    android:layout_marginBottom="12dp"
                    android:insetTop="0dp"
                    android:insetBottom="0dp" />

                <!-- Debug-only manual input -->
                <TextView
                    android:id="@+id/btn_manual_student_input"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="center_horizontal"
                    android:layout_marginBottom="10dp"
                    android:background="?attr/selectableItemBackgroundBorderless"
                    android:clickable="true"
                    android:focusable="true"
                    android:paddingStart="8dp"
                    android:paddingTop="4dp"
                    android:paddingEnd="8dp"
                    android:paddingBottom="4dp"
                    android:text="@string/btn_manual_student_input"
                    android:textColor="@color/text_hint"
                    android:textSize="12sp"
                    android:visibility="gone" />

                <!-- ── SECONDARY BUTTON: Login as Admin / Back to QR ── -->
                <Button
                    android:id="@+id/btnCreateAccount"
                    android:layout_width="match_parent"
                    android:layout_height="50dp"
                    android:text="@string/btn_switch_to_admin_login"
                    android:textColor="@color/green_primary"
                    android:textSize="12sp"
                    android:letterSpacing="0.06"

                    android:background="@drawable/bg_btn_secondary"
                    android:insetTop="0dp"
                    android:insetBottom="0dp" />

            </LinearLayout>

        </androidx.constraintlayout.widget.ConstraintLayout>

    </ScrollView>

</FrameLayout>