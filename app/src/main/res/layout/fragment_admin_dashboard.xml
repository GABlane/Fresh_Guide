<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background_default"
    android:clipToPadding="false"
    android:fillViewport="true"
    android:overScrollMode="never">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingStart="@dimen/screen_horizontal_gutter"
        android:paddingTop="20dp"
        android:paddingEnd="@dimen/screen_horizontal_gutter"
        android:paddingBottom="36dp">

        <TextView
            style="@style/Style.FreshGuide.Text.PageTitle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/admin_dashboard_title" />

        <TextView
            style="@style/Style.FreshGuide.Text.PageSubtitle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:text="@string/admin_dashboard_subtitle" />

        <com.google.android.material.card.MaterialCardView
            style="@style/Style.FreshGuide.Card.Highlight"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="18dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:paddingStart="22dp"
                android:paddingTop="20dp"
                android:paddingEnd="22dp"
                android:paddingBottom="20dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center_vertical"
                    android:orientation="horizontal">

                    <TextView
                        style="@style/Style.FreshGuide.Text.CardTitle"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="Student-facing admin workspace" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:background="@drawable/bg_chip_orange_outline"
                        android:fontFamily="@font/inter_bold"
                        android:paddingStart="10dp"
                        android:paddingTop="4dp"
                        android:paddingEnd="10dp"
                        android:paddingBottom="4dp"
                        android:text="ADMIN"
                        android:textColor="@color/orange_accent"
                        android:textSize="10sp" />
                </LinearLayout>

                <TextView
                    style="@style/Style.FreshGuide.Text.CardBody"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="6dp"
                    android:lineSpacingExtra="2dp"
                    android:text="Every surface here mirrors the student app: shared color system, typography, spacing, cards, and action patterns." />
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <TextView
            style="@style/Style.FreshGuide.Text.FieldLabel"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="20dp"
            android:text="@string/admin_section_overview" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:orientation="horizontal">

            <com.google.android.material.card.MaterialCardView
                android:id="@+id/card_rooms_overview"
                style="@style/Style.FreshGuide.Card.Section"
                android:layout_width="0dp"
                android:layout_height="112dp"
                android:layout_marginEnd="6dp"
                android:layout_weight="1"
                android:clickable="true"
                android:focusable="true"
                android:foreground="?attr/selectableItemBackground">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:gravity="center"
                    android:orientation="vertical"
                    android:padding="12dp">

                    <TextView
                        android:id="@+id/tv_room_count"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:fontFamily="@font/playfair_bold"
                        android:text="0"
                        android:textColor="@color/green_primary"
                        android:textSize="28sp" />

                    <TextView
                        style="@style/Style.FreshGuide.Text.CardBody"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="4dp"
                        android:text="Rooms" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <com.google.android.material.card.MaterialCardView
                android:id="@+id/card_buildings_overview"
                style="@style/Style.FreshGuide.Card.Section"
                android:layout_width="0dp"
                android:layout_height="112dp"
                android:layout_marginStart="6dp"
                android:layout_weight="1"
                android:clickable="true"
                android:focusable="true"
                android:foreground="?attr/selectableItemBackground">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:gravity="center"
                    android:orientation="vertical"
                    android:padding="12dp">

                    <TextView
                        android:id="@+id/tv_building_count"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:fontFamily="@font/playfair_bold"
                        android:text="0"
                        android:textColor="@color/orange_accent"
                        android:textSize="28sp" />

                    <TextView
                        style="@style/Style.FreshGuide.Text.CardBody"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="4dp"
                        android:text="Buildings" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:orientation="horizontal">

            <com.google.android.material.card.MaterialCardView
                android:id="@+id/card_floors_overview"
                style="@style/Style.FreshGuide.Card.Section"
                android:layout_width="0dp"
                android:layout_height="112dp"
                android:layout_marginEnd="6dp"
                android:layout_weight="1"
                android:clickable="true"
                android:focusable="true"
                android:foreground="?attr/selectableItemBackground">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:gravity="center"
                    android:orientation="vertical"
                    android:padding="12dp">

                    <TextView
                        android:id="@+id/tv_floor_count"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:fontFamily="@font/playfair_bold"
                        android:text="0"
                        android:textColor="@color/green_primary"
                        android:textSize="28sp" />

                    <TextView
                        style="@style/Style.FreshGuide.Text.CardBody"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="4dp"
                        android:text="Floors" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <com.google.android.material.card.MaterialCardView
                android:id="@+id/card_routes_overview"
                style="@style/Style.FreshGuide.Card.Section"
                android:layout_width="0dp"
                android:layout_height="112dp"
                android:layout_marginStart="6dp"
                android:layout_weight="1"
                android:clickable="true"
                android:focusable="true"
                android:foreground="?attr/selectableItemBackground">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:gravity="center"
                    android:orientation="vertical"
                    android:padding="12dp">

                    <TextView
                        android:id="@+id/tv_route_count"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:fontFamily="@font/playfair_bold"
                        android:text="0"
                        android:textColor="@color/orange_accent"
                        android:textSize="28sp" />

                    <TextView
                        style="@style/Style.FreshGuide.Text.CardBody"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="4dp"
                        android:text="Routes" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>
        </LinearLayout>

        <TextView
            style="@style/Style.FreshGuide.Text.FieldLabel"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="22dp"
            android:text="@string/admin_section_management" />

        <com.google.android.material.card.MaterialCardView
            style="@style/Style.FreshGuide.Card.Section"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:paddingStart="20dp"
                android:paddingTop="18dp"
                android:paddingEnd="20dp"
                android:paddingBottom="20dp">

                <TextView
                    style="@style/Style.FreshGuide.Text.CardTitle"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Campus structure" />

                <TextView
                    style="@style/Style.FreshGuide.Text.CardBody"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="6dp"
                    android:text="Maintain buildings, floors, rooms, and mapped campus areas without drifting from the student experience." />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="14dp"
                    android:orientation="horizontal">

                    <Button
                        android:id="@+id/btn_manage_buildings"
                        android:layout_width="0dp"
                        android:layout_height="44dp"
                        android:layout_marginEnd="6dp"
                        android:layout_weight="1"
                        android:background="@drawable/bg_form_primary_button"
                        android:fontFamily="@font/inter_bold"
                        android:text="Buildings"
                        android:textAllCaps="false"
                        android:textColor="@color/green_primary"
                        android:textSize="13sp" />

                    <Button
                        android:id="@+id/btn_manage_floors"
                        android:layout_width="0dp"
                        android:layout_height="44dp"
                        android:layout_marginStart="6dp"
                        android:layout_weight="1"
                        android:background="@drawable/bg_form_primary_button"
                        android:fontFamily="@font/inter_bold"
                        android:text="Floors"
                        android:textAllCaps="false"
                        android:textColor="@color/green_primary"
                        android:textSize="13sp" />
                </LinearLayout>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="10dp"
                    android:orientation="horizontal">

                    <Button
                        android:id="@+id/btn_manage_rooms"
                        android:layout_width="0dp"
                        android:layout_height="44dp"
                        android:layout_marginEnd="6dp"
                        android:layout_weight="1"
                        android:background="@drawable/bg_form_primary_button"
                        android:fontFamily="@font/inter_bold"
                        android:text="Rooms"
                        android:textAllCaps="false"
                        android:textColor="@color/green_primary"
                        android:textSize="13sp" />

                    <Button
                        android:id="@+id/btn_manage_campus_areas"
                        android:layout_width="0dp"
                        android:layout_height="44dp"
                        android:layout_marginStart="6dp"
                        android:layout_weight="1"
                        android:background="@drawable/bg_form_primary_button"
                        android:fontFamily="@font/inter_bold"
                        android:text="Campus Areas"
                        android:textAllCaps="false"
                        android:textColor="@color/green_primary"
                        android:textSize="13sp" />
                </LinearLayout>
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <com.google.android.material.card.MaterialCardView
            style="@style/Style.FreshGuide.Card.Section"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:paddingStart="20dp"
                android:paddingTop="18dp"
                android:paddingEnd="20dp"
                android:paddingBottom="20dp">

                <TextView
                    style="@style/Style.FreshGuide.Text.CardTitle"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Navigation data" />

                <TextView
                    style="@style/Style.FreshGuide.Text.CardBody"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="6dp"
                    android:text="Keep origins, facilities, and routes aligned with the same wayfinding patterns students follow on campus." />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="14dp"
                    android:orientation="horizontal">

                    <Button
                        android:id="@+id/btn_manage_facilities"
                        android:layout_width="0dp"
                        android:layout_height="44dp"
                        android:layout_marginEnd="6dp"
                        android:layout_weight="1"
                        android:background="@drawable/bg_form_primary_button"
                        android:fontFamily="@font/inter_bold"
                        android:text="Facilities"
                        android:textAllCaps="false"
                        android:textColor="@color/green_primary"
                        android:textSize="13sp" />

                    <Button
                        android:id="@+id/btn_manage_origins"
                        android:layout_width="0dp"
                        android:layout_height="44dp"
                        android:layout_marginStart="6dp"
                        android:layout_weight="1"
                        android:background="@drawable/bg_form_primary_button"
                        android:fontFamily="@font/inter_bold"
                        android:text="Origins"
                        android:textAllCaps="false"
                        android:textColor="@color/green_primary"
                        android:textSize="13sp" />
                </LinearLayout>

                <Button
                    android:id="@+id/btn_manage_routes"
                    android:layout_width="match_parent"
                    android:layout_height="44dp"
                    android:layout_marginTop="10dp"
                    android:background="@drawable/bg_form_primary_button"
                    android:fontFamily="@font/inter_bold"
                    android:text="Routes"
                    android:textAllCaps="false"
                    android:textColor="@color/green_primary"
                    android:textSize="13sp" />
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <TextView
            style="@style/Style.FreshGuide.Text.FieldLabel"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="22dp"
            android:text="@string/admin_section_release" />

        <com.google.android.material.card.MaterialCardView
            style="@style/Style.FreshGuide.Card.Section"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:paddingStart="20dp"
                android:paddingTop="18dp"
                android:paddingEnd="20dp"
                android:paddingBottom="20dp">

                <TextView
                    style="@style/Style.FreshGuide.Text.CardTitle"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Release pipeline" />

                <TextView
                    android:id="@+id/tv_admin_sync_version"
                    style="@style/Style.FreshGuide.Text.CardBody"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="6dp"
                    android:text="Current data version: Not synced" />

                <TextView
                    style="@style/Style.FreshGuide.Text.CardBody"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="6dp"
                    android:text="Publish the latest local data so students can sync a consistent, up-to-date campus guide." />

                <Button
                    android:id="@+id/btn_publish"
                    android:layout_width="match_parent"
                    android:layout_height="48dp"
                    android:layout_marginTop="14dp"
                    android:background="@drawable/bg_btn_primary"
                    android:fontFamily="@font/inter_bold"
                    android:text="Publish to Students"
                    android:textAllCaps="false"
                    android:textColor="@color/surface_white"
                    android:textSize="14sp" />
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="14dp"
            android:orientation="horizontal">

            <Button
                android:id="@+id/btn_admin_settings"
                android:layout_width="0dp"
                android:layout_height="44dp"
                android:layout_marginEnd="6dp"
                android:layout_weight="1"
                android:background="@drawable/bg_form_primary_button"
                android:fontFamily="@font/inter_bold"
                android:text="Settings"
                android:textAllCaps="false"
                android:textColor="@color/green_primary"
                android:textSize="13sp" />

            <Button
                android:id="@+id/btn_admin_logout"
                android:layout_width="0dp"
                android:layout_height="44dp"
                android:layout_marginStart="6dp"
                android:layout_weight="1"
                android:background="@drawable/bg_chip_orange_outline"
                android:fontFamily="@font/inter_bold"
                android:text="Logout"
                android:textAllCaps="false"
                android:textColor="@color/orange_accent"
                android:textSize="13sp" />
        </LinearLayout>
    </LinearLayout>
</androidx.core.widget.NestedScrollView>
