<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fillViewport="true"
    android:background="@color/background_default">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <!-- Theme -->
        <LinearLayout
            android:id="@+id/card_settings_theme"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="12dp"
            android:background="@color/background_card"
            android:orientation="vertical"
            android:padding="16dp">

            <LinearLayout
                android:id="@+id/header_theme"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Theme"
                    android:textSize="16sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/indicator_theme"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text=">"
                    android:textSize="16sp" />
            </LinearLayout>

            <LinearLayout
                android:id="@+id/content_theme"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:orientation="vertical"
                android:visibility="gone">

                <RadioGroup
                    android:id="@+id/theme_radio_group"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical">

                    <RadioButton
                        android:id="@+id/radio_theme_light"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Light" />

                    <RadioButton
                        android:id="@+id/radio_theme_dark"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Dark" />

                    <RadioButton
                        android:id="@+id/radio_theme_system"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="System Default" />
                </RadioGroup>
            </LinearLayout>
        </LinearLayout>

        <!-- Schedule -->
        <LinearLayout
            android:id="@+id/card_settings_schedule"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="12dp"
            android:background="@color/background_card"
            android:orientation="vertical"
            android:padding="16dp">

            <LinearLayout
                android:id="@+id/header_schedule"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Schedule Preferences"
                    android:textSize="16sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/indicator_schedule"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="v"
                    android:textSize="16sp" />
            </LinearLayout>

            <LinearLayout
                android:id="@+id/content_schedule"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:orientation="vertical">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Default View" />

                <Spinner
                    android:id="@+id/spinner_default_view"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:text="Default Reminder" />

                <Spinner
                    android:id="@+id/spinner_default_reminder"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content" />

                <androidx.appcompat.widget.SwitchCompat
                    android:id="@+id/switch_use_24_hour"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:text="Use 24-hour format" />

                <androidx.appcompat.widget.SwitchCompat
                    android:id="@+id/switch_start_week_sunday"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Start week on Sunday" />
            </LinearLayout>
        </LinearLayout>

        <!-- Notifications -->
        <LinearLayout
            android:id="@+id/card_settings_notifications"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="12dp"
            android:background="@color/background_card"
            android:orientation="vertical"
            android:padding="16dp">

            <LinearLayout
                android:id="@+id/header_notifications"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Notifications"
                    android:textSize="16sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/indicator_notifications"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text=">"
                    android:textSize="16sp" />
            </LinearLayout>

            <LinearLayout
                android:id="@+id/content_notifications"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:orientation="vertical"
                android:visibility="gone">

                <androidx.appcompat.widget.SwitchCompat
                    android:id="@+id/switch_schedule_notifications"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Schedule notifications" />

                <androidx.appcompat.widget.SwitchCompat
                    android:id="@+id/switch_sync_alerts"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Sync alerts" />
            </LinearLayout>
        </LinearLayout>

        <!-- Data and Sync -->
        <LinearLayout
            android:id="@+id/card_settings_data"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="12dp"
            android:background="@color/background_card"
            android:orientation="vertical"
            android:padding="16dp">

            <LinearLayout
                android:id="@+id/header_data"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Data and Sync"
                    android:textSize="16sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/indicator_data"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text=">"
                    android:textSize="16sp" />
            </LinearLayout>

            <LinearLayout
                android:id="@+id/content_data"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:orientation="vertical"
                android:visibility="gone">

                <androidx.appcompat.widget.SwitchCompat
                    android:id="@+id/switch_auto_sync"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Auto sync" />

                <androidx.appcompat.widget.SwitchCompat
                    android:id="@+id/switch_wifi_only"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Sync on Wi-Fi only" />

                <TextView
                    android:id="@+id/tv_sync_version_info"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:text="Data version: Not synced" />

                <Button
                    android:id="@+id/btn_reset_preferences"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:text="Reset Preferences" />
            </LinearLayout>
        </LinearLayout>

        <!-- About -->
        <LinearLayout
            android:id="@+id/card_settings_about"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@color/background_card"
            android:orientation="vertical"
            android:padding="16dp">

            <LinearLayout
                android:id="@+id/header_about"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="About and Support"
                    android:textSize="16sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/indicator_about"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text=">"
                    android:textSize="16sp" />
            </LinearLayout>

            <LinearLayout
                android:id="@+id/content_about"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:orientation="vertical"
                android:visibility="gone">

                <TextView
                    android:id="@+id/tv_app_version_info"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="App version: 1.0" />

                <TextView
                    android:id="@+id/tv_role_info"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:text="Role: student" />
            </LinearLayout>
        </LinearLayout>

    </LinearLayout>
</ScrollView>