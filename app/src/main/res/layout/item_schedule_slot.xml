<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:paddingBottom="16dp">

    <!-- Schedule N label + delete icon -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingBottom="8dp">

        <TextView
            android:id="@+id/tv_slot_label"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Schedule 1"
            android:textSize="13sp"
            android:textColor="#4B8546"
            android:fontFamily="@font/instrument_semibold" />

        <ImageView
            android:id="@+id/btn_delete_slot"
            android:layout_width="22dp"
            android:layout_height="22dp"
            android:src="@drawable/ic_delete_red"
            android:contentDescription="Delete slot"
            android:visibility="gone" />

    </LinearLayout>

    <!-- Day pills -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:paddingBottom="10dp">

        <TextView
            android:id="@+id/slot_mon"
            android:layout_width="0dp"
            android:layout_height="34dp"
            android:layout_weight="1"
            android:layout_marginEnd="4dp"
            android:gravity="center"
            android:text="Mon"
            android:textSize="12sp"
            android:textColor="#1AA514"
            android:background="@drawable/bg_day_pill_outline"
            android:fontFamily="@font/inter_regular" />

        <TextView
            android:id="@+id/slot_tue"
            android:layout_width="0dp"
            android:layout_height="34dp"
            android:layout_weight="1"
            android:layout_marginEnd="4dp"
            android:gravity="center"
            android:text="Tue"
            android:textSize="12sp"
            android:textColor="#1AA514"
            android:background="@drawable/bg_day_pill_outline"
            android:fontFamily="@font/inter_regular" />

        <TextView
            android:id="@+id/slot_wed"
            android:layout_width="0dp"
            android:layout_height="34dp"
            android:layout_weight="1"
            android:layout_marginEnd="4dp"
            android:gravity="center"
            android:text="Wed"
            android:textSize="12sp"
            android:textColor="#1AA514"
            android:background="@drawable/bg_day_pill_outline"
            android:fontFamily="@font/inter_regular" />

        <TextView
            android:id="@+id/slot_thu"
            android:layout_width="0dp"
            android:layout_height="34dp"
            android:layout_weight="1"
            android:layout_marginEnd="4dp"
            android:gravity="center"
            android:text="Thu"
            android:textSize="12sp"
            android:textColor="#1AA514"
            android:background="@drawable/bg_day_pill_outline"
            android:fontFamily="@font/inter_regular" />

        <TextView
            android:id="@+id/slot_fri"
            android:layout_width="0dp"
            android:layout_height="34dp"
            android:layout_weight="1"
            android:layout_marginEnd="4dp"
            android:gravity="center"
            android:text="Fri"
            android:textSize="12sp"
            android:textColor="#1AA514"
            android:background="@drawable/bg_day_pill_outline"
            android:fontFamily="@font/inter_regular" />

        <TextView
            android:id="@+id/slot_sat"
            android:layout_width="0dp"
            android:layout_height="34dp"
            android:layout_weight="1"
            android:gravity="center"
            android:text="Sat"
            android:textSize="12sp"
            android:textColor="#1AA514"
            android:background="@drawable/bg_day_pill_outline"
            android:fontFamily="@font/inter_regular" />

    </LinearLayout>

    <!-- Start Time / End Time -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal">

        <LinearLayout
            android:id="@+id/btn_start_time"
            android:layout_width="0dp"
            android:layout_height="44dp"
            android:layout_weight="1"
            android:layout_marginEnd="8dp"
            android:orientation="horizontal"
            android:gravity="center"
            android:background="@drawable/bg_input_field"
            android:paddingStart="12dp"
            android:paddingEnd="12dp"
            android:clickable="true"
            android:focusable="true">

            <ImageView
                android:layout_width="16dp"
                android:layout_height="16dp"
                android:src="@drawable/clock"
                android:contentDescription="clock"
                android:layout_marginEnd="6dp" />

            <TextView
                android:id="@+id/tv_start_time"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Start Time"
                android:textSize="12sp"
                android:textColor="#CCCCCC"
                android:fontFamily="@font/inter_medium" />

        </LinearLayout>

        <LinearLayout
            android:id="@+id/btn_end_time"
            android:layout_width="0dp"
            android:layout_height="44dp"
            android:layout_weight="1"
            android:orientation="horizontal"
            android:gravity="center"
            android:background="@drawable/bg_input_field"
            android:paddingStart="12dp"
            android:paddingEnd="12dp"
            android:clickable="true"
            android:focusable="true">

            <ImageView
                android:layout_width="16dp"
                android:layout_height="16dp"
                android:src="@drawable/clock"
                android:contentDescription="clock"
                android:layout_marginEnd="6dp" />

            <TextView
                android:id="@+id/tv_end_time"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="End Time"
                android:textSize="12sp"
                android:textColor="#CCCCCC"
                android:fontFamily="@font/inter_medium" />

        </LinearLayout>

    </LinearLayout>

</LinearLayout>