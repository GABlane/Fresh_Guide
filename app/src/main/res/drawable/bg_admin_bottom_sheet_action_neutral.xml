<?xml version="1.0" encoding="utf-8"?>
<selector xmlns:android="http://schemas.android.com/apk/res/android">

    <item android:state_enabled="false">
        <shape android:shape="rectangle">
            <solid android:color="@color/neutral_surface" />
            <stroke
                android:width="1.5dp"
                android:color="@color/neutral_stroke" />
            <corners android:radius="34dp" />
        </shape>
    </item>

    <item android:state_pressed="true">
        <shape android:shape="rectangle">
            <solid android:color="@color/neutral_surface_pressed" />
            <stroke
                android:width="1.5dp"
                android:color="@color/green_primary" />
            <corners android:radius="34dp" />
        </shape>
    </item>

    <item>
        <shape android:shape="rectangle">
            <solid android:color="@color/background_card" />
            <stroke
                android:width="1.5dp"
                android:color="@color/admin_button_outline" />
            <corners android:radius="34dp" />
        </shape>
    </item>

</selector>
